{
  "name": "pi-freerouter",
  "version": "0.1.13",
  "description": "Pi coding agent extension — auto-routes to free OpenRouter models",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "index.ts",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node --test dist/**/*.test.js"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "typescript": "^5.0.0"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "pi-package",
    "openrouter"
  ],
  "license": "MIT"
}
